# ===== MySQL (Hostinger Business) =====
# Crear la BD en hPanel → Bases de datos MySQL.
# Host normalmente es "localhost" cuando Node y MySQL están en el mismo plan.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=u000000000_waremarkt
MYSQL_PASSWORD=tu_password_mysql
MYSQL_DATABASE=u000000000_waremarkt

# ===== App =====
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://waremarkt.com
ADMIN_TOKEN=cambia_este_token_largo_y_aleatorio

# ===== Cloudinary (uploads de fotos/videos) =====
# Dashboard: https://cloudinary.com/console. Sin estas vars, uploads caen a disco local (se pierden en redeploy).
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ===== Stripe =====
# Crea tu cuenta en https://dashboard.stripe.com
# Claves test empiezan con sk_test_ / whsec_ ; live con sk_live_
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===== WhatsApp (checkout alternativo) =====
WHATSAPP_NUMBER=14079434098
